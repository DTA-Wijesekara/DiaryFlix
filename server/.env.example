# CineLog backend environment template
# Copy this file to .env and fill in values appropriate for your environment.
# Never commit the real .env file.

# --- Runtime ---
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# --- Auth ---
# Must be at least 32 characters in production.
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string-of-at-least-32-chars
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# --- Database (MSSQL / msnodesqlv8) ---
DB_SERVER=localhost
DB_NAME=cinemadiary
DB_DRIVER=ODBC Driver 17 for SQL Server
# Trusted connection (Windows auth). Set to "false" to use DB_USER/DB_PASSWORD.
DB_TRUSTED=true
# DB_USER=
# DB_PASSWORD=

# --- CORS ---
# Comma-separated list of allowed origins, or "*" for any.
# In production set this to your frontend URL, e.g. https://cinelog.example.com
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=false

# --- Rate limits ---
# Max login/register attempts per IP per 15 min
RATE_AUTH_MAX=10
# Max general API requests per IP per minute
RATE_API_MAX=120

# --- Password policy ---
PASSWORD_MIN=8

# --- Body parser ---
BODY_LIMIT=256kb

# --- Admin seeding (opt-in only) ---
# If true, an admin is created on first boot using the values below.
# Leave SEED_ADMIN unset or set to "false" to disable default admin creation.
SEED_ADMIN=false
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=  # pick a strong password
# SEED_ADMIN_NAME=Admin
