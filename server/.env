# DiaryFLIX — local development environment
# Do NOT commit this file.

# --- Runtime ---
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# --- Auth ---
JWT_SECRET=diaryflix-dev-secret-change-in-production-32chars-min
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# --- Database ---
# Local PostgreSQL (replace YOUR_PASSWORD with the password you set during installation)
DATABASE_URL=postgresql://neondb_owner:npg_yaWUsgXuk31w@ep-red-feather-anshs9e6.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require
# Set to false for local PostgreSQL without SSL. Neon requires SSL (leave true).
DB_SSL=true

# --- CORS ---
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=false

# --- Rate limits ---
RATE_AUTH_MAX=20
RATE_API_MAX=200

# --- Password policy ---
PASSWORD_MIN=6

# --- Body parser ---
BODY_LIMIT=256kb

# --- Admin seed (runs once on first boot, skipped if email already exists) ---
SEED_ADMIN=true
SEED_ADMIN_EMAIL=admin@diaryflix.com
SEED_ADMIN_PASSWORD=DiaryFlix@2026
SEED_ADMIN_NAME=Admin
