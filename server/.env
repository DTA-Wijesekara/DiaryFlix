# DiaryFLIX — local development environment
# Do NOT commit this file.

# --- Runtime ---
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# --- Auth ---
JWT_SECRET=diaryflix-dev-secret-change-in-production-32chars-min
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# --- Database ---
DB_SERVER=localhost
DB_NAME=cinemadiary
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_TRUSTED=true

# --- CORS ---
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=false

# --- Rate limits ---
RATE_AUTH_MAX=20
RATE_API_MAX=200

# --- Password policy ---
PASSWORD_MIN=6

# --- Body parser ---
BODY_LIMIT=256kb

# --- Admin seed (runs once on first boot, skipped if email already exists) ---
SEED_ADMIN=true
SEED_ADMIN_EMAIL=admin@diaryflix.com
SEED_ADMIN_PASSWORD=DiaryFlix@2026
SEED_ADMIN_NAME=Admin
