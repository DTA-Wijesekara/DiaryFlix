# Copy this file to .env and fill in every value before running docker compose.

# ── Database ──────────────────────────────────────────────────────────────────
# SQL Server SA password — must satisfy complexity:
#   uppercase + lowercase + digit + symbol, min 8 chars
DB_SA_PASSWORD=YourStrong@Password123

# Database name (letters, digits, underscores only)
DB_NAME=cinemadiary

# ── Auth ──────────────────────────────────────────────────────────────────────
# At least 32 random characters.  Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-secret

JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# In production set this to your actual domain, e.g. https://diaryflix.com
CORS_ORIGIN=http://localhost

# ── Admin seed (optional) ─────────────────────────────────────────────────────
# Set SEED_ADMIN=true to create an admin account on the very first boot.
SEED_ADMIN=false
SEED_ADMIN_EMAIL=admin@diaryflix.com
SEED_ADMIN_PASSWORD=AdminPass123!
SEED_ADMIN_NAME=Admin
